meta {
  name: Delete captions or subtitles
  type: http
  seq: 2
}

delete {
  url: {{baseUrl}}/accounts/:account_id/stream/:identifier/captions/:language
  body: json
  auth: apikey
}

params:path {
  language: 
  identifier: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
