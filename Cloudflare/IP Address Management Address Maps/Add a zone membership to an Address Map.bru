meta {
  name: Add a zone membership to an Address Map
  type: http
  seq: 11
}

put {
  url: {{baseUrl}}/accounts/:account_id/addressing/address_maps/:address_map_id/zones/:zone_id
  body: json
  auth: apikey
}

params:path {
  zone_id: 
  address_map_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
