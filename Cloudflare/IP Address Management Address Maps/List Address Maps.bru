meta {
  name: List Address Maps
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/accounts/:account_id/addressing/address_maps
  body: none
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
