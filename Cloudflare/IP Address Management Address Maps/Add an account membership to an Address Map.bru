meta {
  name: Add an account membership to an Address Map
  type: http
  seq: 7
}

put {
  url: {{baseUrl}}/accounts/:account_id/addressing/address_maps/:address_map_id/accounts/:account_id
  body: json
  auth: apikey
}

params:path {
  account_id: 
  address_map_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
