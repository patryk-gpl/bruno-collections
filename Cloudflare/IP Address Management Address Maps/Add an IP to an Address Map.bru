meta {
  name: Add an IP to an Address Map
  type: http
  seq: 9
}

put {
  url: {{baseUrl}}/accounts/:account_id/addressing/address_maps/:address_map_id/ips/:ip_address
  body: json
  auth: apikey
}

params:path {
  ip_address: 
  address_map_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
