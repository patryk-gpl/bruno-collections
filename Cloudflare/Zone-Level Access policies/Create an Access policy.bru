meta {
  name: Create an Access policy
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/zones/:zone_id/access/apps/:app_id/policies
  body: json
  auth: apikey
}

params:path {
  app_id: 
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
