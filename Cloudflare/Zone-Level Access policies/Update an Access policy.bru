meta {
  name: Update an Access policy
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/zones/:zone_id/access/apps/:app_id/policies/:policy_id
  body: json
  auth: apikey
}

params:path {
  policy_id: 
  app_id: 
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
