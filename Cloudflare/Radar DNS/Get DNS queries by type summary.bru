meta {
  name: Get DNS queries by type summary
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/radar/dns/summary/query_type
  body: none
  auth: apikey
}

params:query {
  ~name: 
  ~dateRange: 
  ~dateStart: 
  ~dateEnd: 
  ~asn: 
  ~location: 
  ~continent: 
  ~tld: 
  ~protocol: 
  ~responseCode: 
  ~nodata: 
  ~limitPerGroup: 
  ~format: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
