meta {
  name: Update an Access identity provider
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/accounts/:account_id/access/identity_providers/:identity_provider_id
  body: json
  auth: apikey
}

params:path {
  identity_provider_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {}
}
