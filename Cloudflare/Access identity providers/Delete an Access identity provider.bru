meta {
  name: Delete an Access identity provider
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/accounts/:account_id/access/identity_providers/:identity_provider_id
  body: none
  auth: apikey
}

params:path {
  identity_provider_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
