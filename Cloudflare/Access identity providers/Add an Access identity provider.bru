meta {
  name: Add an Access identity provider
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accounts/:account_id/access/identity_providers
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {}
}
