meta {
  name: Get Region
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/accounts/:account_id/load_balancers/regions/:region_id
  body: none
  auth: apikey
}

params:path {
  region_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
