meta {
  name: Enable validation for a schema
  type: http
  seq: 11
}

patch {
  url: {{baseUrl}}/zones/:zone_id/api_gateway/user_schemas/:schema_id
  body: json
  auth: apikey
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "validation_enabled": ""
  }
}
