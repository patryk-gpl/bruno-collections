meta {
  name: Update operation-level schema validation settings
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/zones/:zone_id/api_gateway/operations/:operation_id/schema_validation
  body: json
  auth: apikey
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "mitigation_action": ""
  }
}
