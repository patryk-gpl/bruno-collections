meta {
  name: Retrieve operation-level schema validation settings
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/zones/:zone_id/api_gateway/operations/:operation_id/schema_validation
  body: none
  auth: apikey
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
