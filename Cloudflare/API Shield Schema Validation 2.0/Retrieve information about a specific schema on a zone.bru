meta {
  name: Retrieve information about a specific schema on a zone
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/zones/:zone_id/api_gateway/user_schemas/:schema_id
  body: none
  auth: apikey
}

params:query {
  ~omit_source: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
