meta {
  name: Retrieve information about all schemas on a zone
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/zones/:zone_id/api_gateway/user_schemas
  body: none
  auth: apikey
}

params:query {
  ~page: 
  ~per_page: 
  ~omit_source: 
  ~validation_enabled: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
