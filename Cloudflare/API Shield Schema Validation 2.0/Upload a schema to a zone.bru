meta {
  name: Upload a schema to a zone
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/zones/:zone_id/api_gateway/user_schemas
  body: multipartForm
  auth: apikey
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:multipart-form {
  file: 
  kind: 
  name: 
  validation_enabled: 
}
