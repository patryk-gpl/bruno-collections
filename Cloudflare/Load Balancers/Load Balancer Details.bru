meta {
  name: Load Balancer Details
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/zones/:zone_id/load_balancers/:load_balancer_id
  body: none
  auth: apikey
}

params:path {
  zone_id: 
  load_balancer_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
