meta {
  name: Stop full PCAP
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/accounts/:account_id/pcaps/:pcap_id/stop
  body: none
  auth: apikey
}

params:path {
  pcap_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
