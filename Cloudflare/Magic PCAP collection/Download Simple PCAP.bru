meta {
  name: Download Simple PCAP
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/accounts/:account_id/pcaps/:pcap_id/download
  body: none
  auth: apikey
}

params:path {
  pcap_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
