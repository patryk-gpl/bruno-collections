meta {
  name: Delete downloads
  type: http
  seq: 1
}

delete {
  url: {{baseUrl}}/accounts/:account_id/stream/:identifier/downloads
  body: none
  auth: apikey
}

params:path {
  identifier: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
