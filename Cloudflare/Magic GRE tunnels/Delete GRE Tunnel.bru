meta {
  name: Delete GRE Tunnel
  type: http
  seq: 4
}

delete {
  url: {{baseUrl}}/accounts/:account_id/magic/gre_tunnels/:gre_tunnel_id
  body: json
  auth: apikey
}

params:path {
  gre_tunnel_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
  ~x-magic-new-hc-target: 
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
