meta {
  name: List GRE tunnels
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/accounts/:account_id/magic/gre_tunnels
  body: none
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
  ~x-magic-new-hc-target: 
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
