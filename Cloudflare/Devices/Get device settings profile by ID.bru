meta {
  name: Get device settings profile by ID
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/accounts/:account_id/devices/policy/:policy_id
  body: none
  auth: apikey
}

params:path {
  policy_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
