meta {
  name: Get the Split Tunnel exclude list
  type: http
  seq: 17
}

get {
  url: {{baseUrl}}/accounts/:account_id/devices/policy/exclude
  body: none
  auth: apikey
}

params:path {
  account_id: 
}

headers {
