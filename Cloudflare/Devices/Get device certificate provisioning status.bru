meta {
  name: Get device certificate provisioning status
  type: http
  seq: 25
}

get {
  url: {{baseUrl}}/zones/:zone_id/devices/policy/certificates
  body: none
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
