meta {
  name: Delete a device settings profile
  type: http
  seq: 8
}

delete {
  url: {{baseUrl}}/accounts/:account_id/devices/policy/:policy_id
  body: json
  auth: apikey
}

params:path {
  policy_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
