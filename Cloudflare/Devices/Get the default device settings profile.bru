meta {
  name: Get the default device settings profile
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/accounts/:account_id/devices/policy
  body: none
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
