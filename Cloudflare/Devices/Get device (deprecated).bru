meta {
  name: Get device (deprecated)
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/accounts/:account_id/devices/:device_id
  body: none
  auth: apikey
}

params:path {
  device_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
