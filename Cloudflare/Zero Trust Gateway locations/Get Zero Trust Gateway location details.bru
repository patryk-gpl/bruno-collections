meta {
  name: Get Zero Trust Gateway location details
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/accounts/:account_id/gateway/locations/:location_id
  body: none
  auth: apikey
}

params:path {
  location_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
