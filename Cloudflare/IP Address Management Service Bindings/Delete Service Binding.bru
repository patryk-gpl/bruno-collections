meta {
  name: Delete Service Binding
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/accounts/:account_id/addressing/prefixes/:prefix_id/bindings/:binding_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  prefix_id: 
  binding_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
