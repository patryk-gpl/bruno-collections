meta {
  name: Add operations to a zone
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/zones/:zone_id/api_gateway/operations
  body: json
  auth: apikey
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  [
    {
      "endpoint": "",
      "host": "",
      "method": ""
    }
  ]
}
