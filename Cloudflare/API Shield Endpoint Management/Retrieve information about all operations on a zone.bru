meta {
  name: Retrieve information about all operations on a zone
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/zones/:zone_id/api_gateway/operations
  body: none
  auth: apikey
}

params:query {
  ~page: 
  ~per_page: 
  ~order: 
  ~direction: 
  ~host: 
  ~method: 
  ~endpoint: 
  ~feature: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
