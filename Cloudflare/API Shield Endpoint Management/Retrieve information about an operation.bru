meta {
  name: Retrieve information about an operation
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/zones/:zone_id/api_gateway/operations/:operation_id
  body: none
  auth: apikey
}

params:query {
  ~feature: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
