meta {
  name: Update log retention flag
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/zones/:zone_id/logs/control/retention/flag
  body: json
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "flag": false
  }
}
