meta {
  name: Delete an account ruleset version
  type: http
  seq: 10
}

delete {
  url: {{baseUrl}}/accounts/:account_id/rulesets/:ruleset_id/versions/:ruleset_version
  body: none
  auth: bearer
}

params:path {
  ruleset_version: 
  ruleset_id: 
  account_id: 
}

auth:bearer {
  token: {{token}}
}
