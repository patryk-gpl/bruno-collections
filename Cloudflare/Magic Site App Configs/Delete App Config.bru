meta {
  name: Delete App Config
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/accounts/:account_id/magic/sites/:site_id/app_configs/:app_config_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  site_id: 
  app_config_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
