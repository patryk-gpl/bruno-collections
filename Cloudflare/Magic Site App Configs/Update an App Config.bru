meta {
  name: Update an App Config
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/accounts/:account_id/magic/sites/:site_id/app_configs/:app_config_id
  body: json
  auth: apikey
}

params:path {
  account_id: 
  site_id: 
  app_config_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "account_app_id": "",
    "breakout": false,
    "managed_app_id": "",
    "priority": 0
  }
}
