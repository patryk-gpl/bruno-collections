meta {
  name: Update a Page Shield policy
  type: http
  seq: 11
}

put {
  url: {{baseUrl}}/zones/:zone_id/page_shield/policies/:policy_id
  body: json
  auth: apikey
}

params:path {
  zone_id: 
  policy_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
