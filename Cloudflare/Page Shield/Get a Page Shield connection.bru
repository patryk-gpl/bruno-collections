meta {
  name: Get a Page Shield connection
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/zones/:zone_id/page_shield/connections/:connection_id
  body: none
  auth: apikey
}

params:path {
  zone_id: 
  connection_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
