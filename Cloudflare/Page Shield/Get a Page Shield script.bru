meta {
  name: Get a Page Shield script
  type: http
  seq: 13
}

get {
  url: {{baseUrl}}/zones/:zone_id/page_shield/scripts/:script_id
  body: none
  auth: apikey
}

params:path {
  zone_id: 
  script_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
