meta {
  name: List Page Shield connections
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/zones/:zone_id/page_shield/connections
  body: none
  auth: apikey
}

params:query {
  ~exclude_urls: 
  ~urls: 
  ~hosts: 
  ~page: 
  ~per_page: 
  ~order_by: 
  ~direction: 
  ~prioritize_malicious: 
  ~exclude_cdn_cgi: 
  ~status: 
  ~page_url: 
  ~export: 
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
