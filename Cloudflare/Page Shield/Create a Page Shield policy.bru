meta {
  name: Create a Page Shield policy
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/zones/:zone_id/page_shield/policies
  body: json
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
