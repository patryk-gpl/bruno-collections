meta {
  name: Get a Page Shield cookie
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/zones/:zone_id/page_shield/cookies/:cookie_id
  body: none
  auth: apikey
}

params:path {
  zone_id: 
  cookie_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
