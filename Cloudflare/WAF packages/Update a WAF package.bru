meta {
  name: Update a WAF package
  type: http
  seq: 3
}

patch {
  url: {{baseUrl}}/zones/:zone_id/firewall/waf/packages/:package_id
  body: json
  auth: apikey
}

params:path {
  package_id: 
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "action_mode": "",
    "sensitivity": ""
  }
}
