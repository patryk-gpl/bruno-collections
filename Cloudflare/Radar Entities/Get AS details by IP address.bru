meta {
  name: Get AS details by IP address
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/radar/entities/asns/ip
  body: none
  auth: apikey
}

params:query {
  ip: 
  ~format: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
