meta {
  name: Get domain
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/accounts/:account_id/registrar/domains/:domain_name
  body: none
  auth: apikey
}

params:path {
  domain_name: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
