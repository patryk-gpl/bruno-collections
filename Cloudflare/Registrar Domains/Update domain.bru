meta {
  name: Update domain
  type: http
  seq: 3
}

put {
  url: {{baseUrl}}/accounts/:account_id/registrar/domains/:domain_name
  body: json
  auth: apikey
}

params:path {
  domain_name: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
