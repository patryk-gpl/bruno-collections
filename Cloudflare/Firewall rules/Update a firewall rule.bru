}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "action": {},
    "filter": {
      "description": "",
      "expression": "",
      "id": "",
      "paused": false,
      "ref": ""
    },
    "id": ""
  }
}
