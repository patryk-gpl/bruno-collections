meta {
  name: Delete a firewall rule
  type: http
  seq: 6
}

delete {
  url: {{baseUrl}}/zones/:zone_id/firewall/rules/:rule_id
  body: json
  auth: apikey
}

params:path {
  rule_id: 
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "delete_filter_if_unused": false
  }
}
