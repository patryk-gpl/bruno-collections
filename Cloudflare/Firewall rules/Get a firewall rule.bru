meta {
  name: Get a firewall rule
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/zones/:zone_id/firewall/rules/:rule_id
  body: none
  auth: apikey
}

params:query {
  ~id: 
}

params:path {
  rule_id: 
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
