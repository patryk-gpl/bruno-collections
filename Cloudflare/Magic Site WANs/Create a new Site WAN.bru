meta {
  name: Create a new Site WAN
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accounts/:account_id/magic/sites/:site_id/wans
  body: json
  auth: apikey
}

params:path {
  account_id: 
  site_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "name": "",
    "physport": 0,
    "priority": 0,
    "static_addressing": {
      "address": "",
      "gateway_address": "",
      "secondary_address": ""
    },
    "vlan_tag": 0
  }
}
