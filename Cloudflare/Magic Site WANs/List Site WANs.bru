meta {
  name: List Site WANs
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/accounts/:account_id/magic/sites/:site_id/wans
  body: none
  auth: apikey
}

params:path {
  account_id: 
  site_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
