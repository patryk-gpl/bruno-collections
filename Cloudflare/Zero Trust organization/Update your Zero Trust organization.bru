meta {
  name: Update your Zero Trust organization
  type: http
  seq: 3
}

put {
  url: {{baseUrl}}/accounts/:account_id/access/organizations
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
