meta {
  name: Revoke all Access tokens for a user
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/accounts/:account_id/access/organizations/revoke_user
  body: json
  auth: apikey
}

params:query {
  ~devices: 
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
