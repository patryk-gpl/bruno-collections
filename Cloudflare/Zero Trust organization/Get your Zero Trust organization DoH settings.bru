meta {
  name: Get your Zero Trust organization DoH settings
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/accounts/:account_id/access/organizations/doh
  body: none
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
