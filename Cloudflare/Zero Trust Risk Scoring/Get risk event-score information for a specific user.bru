meta {
  name: Get risk event/score information for a specific user
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/accounts/:account_id/zt_risk_scoring/:user_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  user_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
