meta {
  name: Get risk score info for all users in the account
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/accounts/:account_id/zt_risk_scoring/summary
  body: none
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
