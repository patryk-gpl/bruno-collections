meta {
  name: Clear the risk score for a particular user
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accounts/:account_id/zt_risk_scoring/:user_id/reset
  body: none
  auth: apikey
}

params:path {
  account_id: 
  user_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
