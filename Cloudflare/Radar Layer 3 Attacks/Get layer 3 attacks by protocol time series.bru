meta {
  name: Get layer 3 attacks by protocol time series
  type: http
  seq: 13
}

get {
  url: {{baseUrl}}/radar/attacks/layer3/timeseries_groups/protocol
  body: none
  auth: apikey
}

params:query {
  ~aggInterval: 
  ~name: 
  ~dateRange: 
  ~dateStart: 
  ~dateEnd: 
  ~location: 
  ~continent: 
  ~ipVersion: 
  ~normalization: 
  ~direction: 
  ~format: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
