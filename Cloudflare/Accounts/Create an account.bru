meta {
  name: Create an account
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accounts
  body: json
  auth: apikey
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "name": "",
    "type": "",
    "unit": {
      "id": ""
    }
  }
}
