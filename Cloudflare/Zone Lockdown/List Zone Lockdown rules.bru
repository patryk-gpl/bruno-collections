meta {
  name: List Zone Lockdown rules
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/zones/:zone_id/firewall/lockdowns
  body: none
  auth: apikey
}

params:query {
  ~page: 
  ~description: 
  ~modified_on: 
  ~ip: 
  ~priority: 
  ~uri_search: 
  ~ip_range_search: 
  ~per_page: 
  ~created_on: 
  ~description_search: 
  ~ip_search: 
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
