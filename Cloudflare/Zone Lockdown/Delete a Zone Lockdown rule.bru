meta {
  name: Delete a Zone Lockdown rule
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/zones/:zone_id/firewall/lockdowns/:lock_downs_id
  body: json
  auth: apikey
}

params:path {
  lock_downs_id: 
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
