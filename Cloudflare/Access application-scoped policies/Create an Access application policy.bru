meta {
  name: Create an Access application policy
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accounts/:account_id/access/apps/:app_id/policies
  body: json
  auth: apikey
}

params:path {
  app_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {}
}
