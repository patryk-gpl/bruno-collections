meta {
  name: Reset device settings for a Zero Trust account with defaults. This turns off all proxying.
  type: http
  seq: 1
}

delete {
  url: {{baseUrl}}/accounts/:account_id/devices/settings
  body: none
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
