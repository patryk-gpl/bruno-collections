meta {
  name: Patch Zero Trust account configuration
  type: http
  seq: 8
}

patch {
  url: {{baseUrl}}/accounts/:account_id/gateway/configuration
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
