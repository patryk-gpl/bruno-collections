meta {
  name: Get device settings for a Zero Trust account
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/accounts/:account_id/devices/settings
  body: none
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
