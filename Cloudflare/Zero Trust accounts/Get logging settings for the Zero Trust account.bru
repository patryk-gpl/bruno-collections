meta {
  name: Get logging settings for the Zero Trust account
  type: http
  seq: 11
}

get {
  url: {{baseUrl}}/accounts/:account_id/gateway/logging
  body: none
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
