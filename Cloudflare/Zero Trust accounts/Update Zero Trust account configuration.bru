meta {
  name: Update Zero Trust account configuration
  type: http
  seq: 9
}

put {
  url: {{baseUrl}}/accounts/:account_id/gateway/configuration
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
