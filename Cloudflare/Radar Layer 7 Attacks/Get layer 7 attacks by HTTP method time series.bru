meta {
  name: Get layer 7 attacks by HTTP method time series
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/radar/attacks/layer7/timeseries_groups/http_method
  body: none
  auth: apikey
}

params:query {
  ~aggInterval: 
  ~name: 
  ~dateRange: 
  ~dateStart: 
  ~dateEnd: 
  ~asn: 
  ~location: 
  ~continent: 
  ~ipVersion: 
  ~httpVersion: 
  ~mitigationProduct: 
  ~normalization: 
  ~limitPerGroup: 
  ~format: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
