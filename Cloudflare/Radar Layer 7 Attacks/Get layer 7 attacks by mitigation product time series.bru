meta {
  name: Get layer 7 attacks by mitigation product time series
  type: http
  seq: 14
}

get {
  url: {{baseUrl}}/radar/attacks/layer7/timeseries_groups/mitigation_product
  body: none
  auth: apikey
}

params:query {
  ~aggInterval: 
  ~name: 
  ~dateRange: 
  ~dateStart: 
  ~dateEnd: 
  ~asn: 
  ~location: 
  ~continent: 
  ~ipVersion: 
  ~httpVersion: 
  ~httpMethod: 
  ~normalization: 
  ~limitPerGroup: 
  ~format: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
