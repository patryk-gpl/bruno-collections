meta {
  name: List Regional Hostnames
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/zones/:zone_id/addressing/regional_hostnames
  body: none
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
