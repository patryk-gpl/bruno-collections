meta {
  name: Update Regional Hostname
  type: http
  seq: 6
}

patch {
  url: {{baseUrl}}/zones/:zone_id/addressing/regional_hostnames/:hostname
  body: json
  auth: apikey
}

params:path {
  zone_id: 
  hostname: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "region_key": ""
  }
}
