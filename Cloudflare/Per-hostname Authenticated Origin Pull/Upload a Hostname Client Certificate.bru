meta {
  name: Upload a Hostname Client Certificate
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/zones/:zone_id/origin_tls_client_auth/hostnames/certificates
  body: json
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "certificate": "",
    "private_key": ""
  }
}
