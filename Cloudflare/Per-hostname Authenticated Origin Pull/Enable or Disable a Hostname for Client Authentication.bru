meta {
  name: Enable or Disable a Hostname for Client Authentication
  type: http
  seq: 1
}

put {
  url: {{baseUrl}}/zones/:zone_id/origin_tls_client_auth/hostnames
  body: json
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
