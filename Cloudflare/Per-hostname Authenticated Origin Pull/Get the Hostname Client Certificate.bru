meta {
  name: Get the Hostname Client Certificate
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/zones/:zone_id/origin_tls_client_auth/hostnames/certificates/:certificate_id
  body: none
  auth: apikey
}

params:path {
  certificate_id: 
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
