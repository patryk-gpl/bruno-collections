meta {
  name: Get the Hostname Status for Client Authentication
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/zones/:zone_id/origin_tls_client_auth/hostnames/:hostname
  body: none
  auth: apikey
}

params:path {
  hostname: 
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
