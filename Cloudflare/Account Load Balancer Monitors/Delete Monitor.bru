meta {
  name: Delete Monitor
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/accounts/:account_id/load_balancers/monitors/:monitor_id
  body: json
  auth: apikey
}

params:path {
  monitor_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
