meta {
  name: Get a User Agent Blocking rule
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/zones/:zone_id/firewall/ua_rules/:ua_rule_id
  body: none
  auth: apikey
}

params:path {
  ua_rule_id: 
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
