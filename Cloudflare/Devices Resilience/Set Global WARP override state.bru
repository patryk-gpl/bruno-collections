meta {
  name: Set Global WARP override state
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accounts/:account_id/devices/resilience/disconnect
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "disconnect": false,
    "justification": ""
  }
}
