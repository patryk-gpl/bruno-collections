meta {
  name: Validate a DLP regex pattern
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accounts/:account_id/dlp/patterns/validate
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "max_match_bytes": 0,
    "regex": ""
  }
}
