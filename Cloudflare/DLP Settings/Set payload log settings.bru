meta {
  name: Set payload log settings
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/accounts/:account_id/dlp/payload_log
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "public_key": ""
  }
}
