meta {
  name: Fetch limits associated with DLP for account
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/accounts/:account_id/dlp/limits
  body: none
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
