meta {
  name: Update an mTLS certificate
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/accounts/:account_id/access/certificates/:certificate_id
  body: json
  auth: apikey
}

params:path {
  certificate_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
