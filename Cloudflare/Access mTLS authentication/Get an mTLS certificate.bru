meta {
  name: Get an mTLS certificate
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/accounts/:account_id/access/certificates/:certificate_id
  body: none
  auth: apikey
}

params:path {
  certificate_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
