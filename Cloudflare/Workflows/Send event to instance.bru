meta {
  name: Send event to instance
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/accounts/:account_id/workflows/:workflow_name/instances/:instance_id/events/:event_type
  body: json
  auth: apikey
}

params:path {
  workflow_name: 
  instance_id: 
  event_type: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {}
}
