meta {
  name: Get logs and status from instance
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/accounts/:account_id/workflows/:workflow_name/instances/:instance_id
  body: none
  auth: apikey
}

params:path {
  workflow_name: 
  instance_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
