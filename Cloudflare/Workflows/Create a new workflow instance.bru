meta {
  name: Create a new workflow instance
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/accounts/:account_id/workflows/:workflow_name/instances
  body: json
  auth: apikey
}

params:path {
  workflow_name: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "instance_id": "",
    "instance_retention": {},
    "params": {}
  }
}
