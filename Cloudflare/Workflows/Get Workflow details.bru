meta {
  name: Get Workflow details
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/accounts/:account_id/workflows/:workflow_name
  body: none
  auth: apikey
}

params:path {
  workflow_name: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
