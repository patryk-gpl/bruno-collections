meta {
  name: List of workflow instances
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/accounts/:account_id/workflows/:workflow_name/instances
  body: none
  auth: apikey
}

params:query {
  ~page: 
  ~per_page: 
  ~cursor: 
  ~status: 
  ~date_start: 
  ~date_end: 
}

params:path {
  workflow_name: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
