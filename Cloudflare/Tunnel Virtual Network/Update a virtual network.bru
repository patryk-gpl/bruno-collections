meta {
  name: Update a virtual network
  type: http
  seq: 5
}

patch {
  url: {{baseUrl}}/accounts/:account_id/teamnet/virtual_networks/:virtual_network_id
  body: json
  auth: apikey
}

params:path {
  account_id: 
  virtual_network_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "comment": "",
    "is_default_network": false,
    "name": ""
  }
}
