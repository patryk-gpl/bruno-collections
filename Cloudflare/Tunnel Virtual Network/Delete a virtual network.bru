meta {
  name: Delete a virtual network
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/accounts/:account_id/teamnet/virtual_networks/:virtual_network_id
  body: json
  auth: apikey
}

params:path {
  virtual_network_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
