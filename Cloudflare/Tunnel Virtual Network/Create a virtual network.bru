meta {
  name: Create a virtual network
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accounts/:account_id/teamnet/virtual_networks
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "comment": "",
    "is_default": false,
    "is_default_network": false,
    "name": ""
  }
}
