meta {
  name: Get top locations by AS112 DNS queries with DNSSEC support
  type: http
  seq: 15
}

get {
  url: {{baseUrl}}/radar/as112/top/locations/dnssec/:dnssec
  body: none
  auth: apikey
}

params:query {
  ~limit: 
  ~name: 
  ~dateRange: 
  ~dateStart: 
  ~dateEnd: 
  ~location: 
  ~continent: 
  ~format: 
}

params:path {
  dnssec: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
