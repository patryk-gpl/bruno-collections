meta {
  name: Get top locations by AS112 DNS queries for an IP version
  type: http
  seq: 17
}

get {
  url: {{baseUrl}}/radar/as112/top/locations/ip_version/:ip_version
  body: none
  auth: apikey
}

params:query {
  ~limit: 
  ~name: 
  ~dateRange: 
  ~dateStart: 
  ~dateEnd: 
  ~location: 
  ~continent: 
  ~format: 
}

params:path {
  ip_version: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
