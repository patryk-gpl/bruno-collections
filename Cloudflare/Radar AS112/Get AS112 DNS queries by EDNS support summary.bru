meta {
  name: Get AS112 DNS queries by EDNS support summary
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/radar/as112/timeseries_groups/edns
  body: none
  auth: apikey
}

params:query {
  ~aggInterval: 
  ~name: 
  ~dateRange: 
  ~dateStart: 
  ~dateEnd: 
  ~location: 
  ~continent: 
  ~queryType: 
  ~protocol: 
  ~responseCode: 
  ~format: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
