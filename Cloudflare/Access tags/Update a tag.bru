meta {
  name: Update a tag
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/accounts/:account_id/access/tags/:tag_name
  body: json
  auth: apikey
}

params:path {
  account_id: 
  tag_name: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "created_at": "",
    "name": "",
    "updated_at": ""
  }
}
