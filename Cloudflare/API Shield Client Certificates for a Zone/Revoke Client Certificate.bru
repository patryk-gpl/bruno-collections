meta {
  name: Revoke Client Certificate
  type: http
  seq: 5
}

delete {
  url: {{baseUrl}}/zones/:zone_id/client_certificates/:client_certificate_id
  body: none
  auth: apikey
}

params:path {
  zone_id: 
  client_certificate_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
