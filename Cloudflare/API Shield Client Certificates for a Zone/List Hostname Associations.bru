meta {
  name: List Hostname Associations
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/zones/:zone_id/certificate_authorities/hostname_associations
  body: none
  auth: apikey
}

params:query {
  ~mtls_certificate_id: 
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
