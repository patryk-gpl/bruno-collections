meta {
  name: Create a Route
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/accounts/:account_id/magic/routes
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "description": "",
    "nexthop": "",
    "prefix": "",
    "priority": 0,
    "scope": {
      "colo_names": [],
      "colo_regions": []
    },
    "weight": 0
  }
}
