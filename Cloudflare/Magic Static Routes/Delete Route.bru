meta {
  name: Delete Route
  type: http
  seq: 5
}

delete {
  url: {{baseUrl}}/accounts/:account_id/magic/routes/:route_id
  body: json
  auth: apikey
}

params:path {
  route_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
