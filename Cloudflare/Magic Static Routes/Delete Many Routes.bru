meta {
  name: Delete Many Routes
  type: http
  seq: 1
}

delete {
  url: {{baseUrl}}/accounts/:account_id/magic/routes
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "routes": []
  }
}
