meta {
  name: Delete a custom page
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/accounts/:account_id/access/custom_pages/:custom_page_id
  body: none
  auth: apikey
}

params:path {
  custom_page_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
