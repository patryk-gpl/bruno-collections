meta {
  name: Update a custom page
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/accounts/:account_id/access/custom_pages/:custom_page_id
  body: json
  auth: apikey
}

params:path {
  custom_page_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "app_count": 0,
    "created_at": "",
    "custom_html": "",
    "name": "",
    "type": "",
    "uid": "",
    "updated_at": ""
  }
}
