meta {
  name: Create a custom page
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accounts/:account_id/access/custom_pages
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "app_count": 0,
    "created_at": "",
    "custom_html": "",
    "name": "",
    "type": "",
    "uid": "",
    "updated_at": ""
  }
}
