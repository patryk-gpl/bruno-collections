meta {
  name: Grant permission to indicator feed
  type: http
  seq: 7
}

put {
  url: {{baseUrl}}/accounts/:account_id/intel/indicator-feeds/permissions/add
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
