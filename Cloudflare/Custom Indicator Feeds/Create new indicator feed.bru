meta {
  name: Create new indicator feed
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accounts/:account_id/intel/indicator-feeds
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
