meta {
  name: Update indicator feed metadata
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/accounts/:account_id/intel/indicator-feeds/:feed_id
  body: json
  auth: apikey
}

params:path {
  account_id: 
  feed_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
