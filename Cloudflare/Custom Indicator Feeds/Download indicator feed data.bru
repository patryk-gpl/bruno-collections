meta {
  name: Download indicator feed data
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/accounts/:account_id/intel/indicator_feeds/:feed_id/download
  body: none
  auth: apikey
}

params:path {
  account_id: 
  feed_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
