meta {
  name: Update a service token
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/zones/:zone_id/access/service_tokens/:service_token_id
  body: json
  auth: apikey
}

params:path {
  service_token_id: 
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
