meta {
  name: Delete list items
  type: http
  seq: 6
}

delete {
  url: {{baseUrl}}/accounts/:account_id/rules/lists/:list_id/items
  body: json
  auth: apikey
}

params:path {
  list_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "items": [
      {
        "id": ""
      }
    ]
  }
}
