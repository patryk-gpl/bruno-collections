meta {
  name: Update Fallback Origin for Custom Hostnames
  type: http
  seq: 3
}

put {
  url: {{baseUrl}}/zones/:zone_id/custom_hostnames/fallback_origin
  body: json
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "origin": ""
  }
}
