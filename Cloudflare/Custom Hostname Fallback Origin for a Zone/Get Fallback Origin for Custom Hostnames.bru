meta {
  name: Get Fallback Origin for Custom Hostnames
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/zones/:zone_id/custom_hostnames/fallback_origin
  body: none
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
