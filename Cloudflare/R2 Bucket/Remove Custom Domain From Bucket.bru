meta {
  name: Remove Custom Domain From Bucket
  type: http
  seq: 15
}

delete {
  url: {{baseUrl}}/accounts/:account_id/r2/buckets/:bucket_name/domains/custom/:domain
  body: none
  auth: bearer
}

params:path {
  bucket_name: 
  account_id: 
  domain: 
}

headers {
  ~cf-r2-jurisdiction: 
}

auth:bearer {
  token: {{token}}
}
