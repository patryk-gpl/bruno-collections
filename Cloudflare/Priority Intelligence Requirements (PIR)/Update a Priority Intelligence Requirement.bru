  account_id: 
  priority_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "labels": [],
    "priority": 0,
    "requirement": "",
    "tlp": ""
  }
}
