meta {
  name: Upload LOA Document
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/accounts/:account_id/addressing/loa_documents
  body: multipartForm
  auth: apikey
}

params:path {
  account_id: 
}

headers {
