meta {
  name: Retrieve a list of all slots matching the specified parameters
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/accounts/:account_id/cni/slots
  body: none
  auth: apikey
}

params:query {
  ~address_contains: 
  ~site: 
  ~speed: 
  ~occupied: 
  ~cursor: 
  ~limit: 
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
