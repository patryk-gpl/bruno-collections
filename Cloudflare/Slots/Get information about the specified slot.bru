meta {
  name: Get information about the specified slot
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/accounts/:account_id/cni/slots/:slot
  body: none
  auth: apikey
}

params:path {
  slot: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
