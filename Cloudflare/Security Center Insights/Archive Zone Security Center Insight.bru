meta {
  name: Archive Zone Security Center Insight
  type: http
  seq: 13
}

put {
  url: {{baseUrl}}/zones/:zone_id/security-center/insights/:issue_id/dismiss
  body: json
  auth: apikey
}

params:path {
  zone_id: 
  issue_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "dismiss": false
  }
}
