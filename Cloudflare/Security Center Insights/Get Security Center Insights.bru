meta {
  name: Get Security Center Insights
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/accounts/:account_id/security-center/insights
  body: none
  auth: apikey
}

params:query {
  ~dismissed: 
  ~issue_class: 
  ~issue_type: 
  ~product: 
  ~severity: 
  ~subject: 
  ~issue_class~neq: 
  ~issue_type~neq: 
  ~product~neq: 
  ~severity~neq: 
  ~subject~neq: 
  ~page: 
  ~per_page: 
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
