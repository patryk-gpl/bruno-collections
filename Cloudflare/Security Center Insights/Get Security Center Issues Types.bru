meta {
  name: Get Security Center Issues Types
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/accounts/:account_id/intel/attack-surface-report/issue-types
  body: none
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
