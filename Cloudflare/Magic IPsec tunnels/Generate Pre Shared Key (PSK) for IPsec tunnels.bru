meta {
  name: Generate Pre Shared Key (PSK) for IPsec tunnels
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/accounts/:account_id/magic/ipsec_tunnels/:ipsec_tunnel_id/psk_generate
  body: json
  auth: apikey
}

params:path {
  ipsec_tunnel_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
