meta {
  name: Delete IPsec Tunnel
  type: http
  seq: 4
}

delete {
  url: {{baseUrl}}/accounts/:account_id/magic/ipsec_tunnels/:ipsec_tunnel_id
  body: json
  auth: apikey
}

params:path {
  ipsec_tunnel_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
  ~x-magic-new-hc-target: 
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
