meta {
  name: List Subnets
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/accounts/:account_id/zerotrust/subnets
  body: none
  auth: apikey
}

params:query {
  ~name: 
  ~comment: 
  ~network: 
  ~existed_at: 
  ~address_family: 
  ~is_default_network: 
  ~is_deleted: 
  ~sort_order: 
  ~subnet_types: 
  ~per_page: 
  ~page: 
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
