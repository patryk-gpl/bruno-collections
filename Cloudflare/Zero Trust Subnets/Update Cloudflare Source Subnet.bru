meta {
  name: Update Cloudflare Source Subnet
  type: http
  seq: 2
}

patch {
  url: {{baseUrl}}/accounts/:account_id/zerotrust/subnets/cloudflare_source/:address_family
  body: json
  auth: apikey
}

params:path {
  account_id: 
  address_family: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "comment": "",
    "name": "",
    "network": ""
  }
}
