meta {
  name: List Custom Hostnames
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/zones/:zone_id/custom_hostnames
  body: none
  auth: apikey
}

params:query {
  ~hostname: 
  ~id: 
  ~page: 
  ~per_page: 
  ~order: 
  ~direction: 
  ~ssl: 
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
