}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "custom_metadata": {},
    "custom_origin_server": "",
    "custom_origin_sni": "",
    "ssl": {}
  }
}
