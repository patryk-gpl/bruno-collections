meta {
  name: Refresh a service token
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/accounts/:account_id/access/service_tokens/:service_token_id/refresh
  body: none
  auth: apikey
}

params:path {
  service_token_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
