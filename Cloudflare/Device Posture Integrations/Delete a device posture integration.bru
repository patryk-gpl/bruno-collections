meta {
  name: Delete a device posture integration
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/accounts/:account_id/devices/posture/integration/:integration_id
  body: json
  auth: apikey
}

params:path {
  integration_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
