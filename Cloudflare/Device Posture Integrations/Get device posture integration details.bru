meta {
  name: Get device posture integration details
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/accounts/:account_id/devices/posture/integration/:integration_id
  body: none
  auth: apikey
}

params:path {
  integration_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
