meta {
  name: SSL Verification Details
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/zones/:zone_id/ssl/verification
  body: none
  auth: apikey
}

params:query {
  ~retry: 
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
