meta {
  name: Create SSL Configuration
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/zones/:zone_id/custom_certificates
  body: json
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "bundle_method": "",
    "certificate": "",
    "geo_restrictions": {
      "label": ""
    },
    "policy": "",
    "private_key": "",
    "type": ""
  }
}
