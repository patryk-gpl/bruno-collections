meta {
  name: Re-prioritize SSL Certificates
  type: http
  seq: 6
}

put {
  url: {{baseUrl}}/zones/:zone_id/custom_certificates/prioritize
  body: json
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
