meta {
  name: Delete User Subscription
  type: http
  seq: 2
}

delete {
  url: {{baseUrl}}/user/subscriptions/:identifier
  body: json
  auth: apikey
}

params:path {
  identifier: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
