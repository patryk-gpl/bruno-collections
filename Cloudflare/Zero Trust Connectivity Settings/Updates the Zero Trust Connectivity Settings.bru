meta {
  name: Updates the Zero Trust Connectivity Settings
  type: http
  seq: 2
}

patch {
  url: {{baseUrl}}/accounts/:account_id/zerotrust/connectivity_settings
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "icmp_proxy_enabled": false,
    "offramp_warp_enabled": false
  }
}
