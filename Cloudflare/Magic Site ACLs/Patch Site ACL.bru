meta {
  name: Patch Site ACL
  type: http
  seq: 5
}

patch {
  url: {{baseUrl}}/accounts/:account_id/magic/sites/:site_id/acls/:acl_id
  body: json
  auth: apikey
}

params:path {
  site_id: 
  account_id: 
  acl_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "description": "",
    "forward_locally": false,
    "lan_1": {
      "lan_id": "",
      "lan_name": "",
      "port_ranges": [],
      "ports": [],
      "subnets": []
    },
    "lan_2": {},
    "name": "",
    "protocols": [],
    "unidirectional": false
  }
}
