meta {
  name: List Leaked Credential Checks Custom Detections
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/zones/:zone_id/leaked-credential-checks/detections
  body: none
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
