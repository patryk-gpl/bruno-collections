meta {
  name: Set Leaked Credential Checks Status
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/zones/:zone_id/leaked-credential-checks
  body: json
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "enabled": false
  }
}
