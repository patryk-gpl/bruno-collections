meta {
  name: Get a custom page
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/accounts/:account_identifier/custom_pages/:identifier
  body: none
  auth: apikey
}

params:path {
  identifier: 
  account_identifier: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
