meta {
  name: Get network traffic time series
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/radar/netflows/timeseries
  body: none
  auth: apikey
}

params:query {
  ~aggInterval: 
  ~name: 
  ~dateRange: 
  ~dateStart: 
  ~dateEnd: 
  ~product: 
  ~asn: 
  ~location: 
  ~continent: 
  ~normalization: 
  ~format: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
