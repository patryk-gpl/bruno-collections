meta {
  name: Delete watermark profiles
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/accounts/:account_id/stream/watermarks/:identifier
  body: json
  auth: apikey
}

params:path {
  identifier: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
