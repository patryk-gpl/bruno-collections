meta {
  name: Create a new App
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accounts/:account_id/magic/apps
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "hostnames": [],
    "ip_subnets": [],
    "name": "",
    "type": ""
  }
}
