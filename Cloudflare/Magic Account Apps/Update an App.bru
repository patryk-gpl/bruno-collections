meta {
  name: Update an App
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/accounts/:account_id/magic/apps/:account_app_id
  body: json
  auth: apikey
}

params:path {
  account_id: 
  account_app_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "hostnames": [],
    "ip_subnets": [],
    "name": "",
    "type": ""
  }
}
