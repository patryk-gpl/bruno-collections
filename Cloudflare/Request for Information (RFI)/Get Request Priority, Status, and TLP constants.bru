meta {
  name: Get Request Priority, Status, and TLP constants
  type: http
  seq: 14
}

get {
  url: {{baseUrl}}/accounts/:account_id/cloudforce-one/requests/constants
  body: none
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
