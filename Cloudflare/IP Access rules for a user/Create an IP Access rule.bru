meta {
  name: Create an IP Access rule
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/user/firewall/access_rules/rules
  body: json
  auth: apikey
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "configuration": {},
    "mode": "",
    "notes": ""
  }
}
