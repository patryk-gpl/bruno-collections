meta {
  name: Delete an IP Access rule
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/user/firewall/access_rules/rules/:rule_id
  body: json
  auth: apikey
}

params:path {
  rule_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
