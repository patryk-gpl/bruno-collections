meta {
  name: Get Workers AI tasks time series
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/radar/ai/inference/timeseries_groups/task
  body: none
  auth: apikey
}

params:query {
  ~aggInterval: 
  ~name: 
  ~dateRange: 
  ~dateStart: 
  ~dateEnd: 
  ~limitPerGroup: 
  ~format: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
