meta {
  name: Get certificate log details
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/radar/ct/logs/:log_slug
  body: none
  auth: apikey
}

params:query {
  ~format: 
}

params:path {
  log_slug: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
