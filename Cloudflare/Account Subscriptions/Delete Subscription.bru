meta {
  name: Delete Subscription
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/accounts/:account_id/subscriptions/:subscription_identifier
  body: json
  auth: apikey
}

params:path {
  subscription_identifier: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
