  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/radar/ai/bots/summary/user_agent
  body: none
  auth: apikey
}

params:query {
  ~name: 
  ~dateRange: 
  ~dateStart: 
  ~dateEnd: 
  ~asn: 
  ~location: 
  ~continent: 
  ~limitPerGroup: 
  ~format: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
