meta {
  name: Get AI bots HTTP requests time series
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/radar/ai/bots/timeseries
  body: none
  auth: apikey
}

params:query {
  ~aggInterval: 
  ~name: 
  ~dateRange: 
  ~dateStart: 
  ~dateEnd: 
  ~asn: 
  ~location: 
  ~continent: 
  ~crawlPurpose: 
  ~userAgent: 
  ~industry: 
  ~vertical: 
  ~limitPerGroup: 
  ~format: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
