meta {
  name: Get an AI Gateway Dynamic Route Version.
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/accounts/:account_id/ai-gateway/gateways/:gateway_id/routes/:id/versions/:version_id
  body: none
  auth: bearer
}

params:path {
  account_id: 
  gateway_id: 
  id: 
  version_id: 
}

auth:bearer {
  token: {{token}}
}
