meta {
  name: List custom pages
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/zones/:zone_identifier/custom_pages
  body: none
  auth: apikey
}

params:path {
  zone_identifier: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
