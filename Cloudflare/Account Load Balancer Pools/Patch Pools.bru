meta {
  name: Patch Pools
  type: http
  seq: 2
}

patch {
  url: {{baseUrl}}/accounts/:account_id/load_balancers/pools
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
