meta {
  name: Preview Pool
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/accounts/:account_id/load_balancers/pools/:pool_id/preview
  body: json
  auth: apikey
}

params:path {
  pool_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
