meta {
  name: Creates a new document fingerprint.
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accounts/:account_id/dlp/document_fingerprints
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "description": "",
    "match_percent": 0,
    "name": ""
  }
}
