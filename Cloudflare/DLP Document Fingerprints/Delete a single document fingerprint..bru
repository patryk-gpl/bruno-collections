meta {
  name: Delete a single document fingerprint.
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/accounts/:account_id/dlp/document_fingerprints/:document_fingerprint_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  document_fingerprint_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
