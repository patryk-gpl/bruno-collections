meta {
  name: Delete a specified CNI object
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/accounts/:account_id/cni/cnis/:cni
  body: none
  auth: apikey
}

params:path {
  cni: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
