meta {
  name: Get a WAF override
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/zones/:zone_id/firewall/waf/overrides/:overrides_id
  body: none
  auth: apikey
}

params:path {
  overrides_id: 
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
