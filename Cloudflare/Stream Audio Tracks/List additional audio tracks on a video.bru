meta {
  name: List additional audio tracks on a video
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/accounts/:account_id/stream/:identifier/audio
  body: none
  auth: apikey
}

params:path {
  account_id: 
  identifier: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
