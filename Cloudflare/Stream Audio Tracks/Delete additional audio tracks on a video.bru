meta {
  name: Delete additional audio tracks on a video
  type: http
  seq: 2
}

delete {
  url: {{baseUrl}}/accounts/:account_id/stream/:identifier/audio/:audio_identifier
  body: none
  auth: apikey
}

params:path {
  account_id: 
  identifier: 
  audio_identifier: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
