meta {
  name: Add audio tracks to a video
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/accounts/:account_id/stream/:identifier/audio/copy
  body: json
  auth: apikey
}

params:path {
  account_id: 
  identifier: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "label": "",
    "url": ""
  }
}
