meta {
  name: Deletes the stripe config for a crawler
  type: http
  seq: 1
}

delete {
  url: {{baseUrl}}/accounts/:account_id/pay-per-crawl/crawler/stripe
  body: none
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
