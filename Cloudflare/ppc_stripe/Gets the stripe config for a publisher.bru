meta {
  name: Gets the stripe config for a publisher
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/accounts/:account_id/pay-per-crawl/publisher/stripe
  body: none
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
