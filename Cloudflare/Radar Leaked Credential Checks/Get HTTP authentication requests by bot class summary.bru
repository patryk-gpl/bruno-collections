meta {
  name: Get HTTP authentication requests by bot class summary
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/radar/leaked_credential_checks/summary/bot_class
  body: none
  auth: apikey
}

params:query {
  ~name: 
  ~dateRange: 
  ~dateStart: 
  ~dateEnd: 
  ~compromised: 
  ~format: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
