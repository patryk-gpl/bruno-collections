meta {
  name: Get a Bookmark application
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/accounts/:account_id/access/bookmarks/:bookmark_id
  body: none
  auth: apikey
}

params:path {
  bookmark_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
