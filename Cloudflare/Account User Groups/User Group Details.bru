meta {
  name: User Group Details
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/accounts/:account_id/iam/user_groups/:user_group_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  user_group_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
