meta {
  name: Remove User Group Member
  type: http
  seq: 9
}

delete {
  url: {{baseUrl}}/accounts/:account_id/iam/user_groups/:user_group_id/members/:member_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  user_group_id: 
  member_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
