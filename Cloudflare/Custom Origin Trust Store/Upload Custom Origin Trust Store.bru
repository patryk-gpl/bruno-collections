meta {
  name: Upload Custom Origin Trust Store
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/zones/:zone_id/acm/custom_trust_store
  body: json
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
