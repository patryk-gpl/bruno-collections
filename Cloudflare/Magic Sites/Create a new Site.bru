meta {
  name: Create a new Site
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accounts/:account_id/magic/sites
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "connector_id": "",
    "description": "",
    "ha_mode": false,
    "location": {
      "lat": "",
      "lon": ""
    },
    "name": "",
    "secondary_connector_id": ""
  }
}
