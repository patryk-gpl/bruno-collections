meta {
  name: Patch discovered operations
  type: http
  seq: 3
}

patch {
  url: {{baseUrl}}/zones/:zone_id/api_gateway/discovery/operations
  body: json
  auth: apikey
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {}
}
