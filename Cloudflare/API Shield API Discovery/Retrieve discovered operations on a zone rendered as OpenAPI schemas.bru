meta {
  name: Retrieve discovered operations on a zone rendered as OpenAPI schemas
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/zones/:zone_id/api_gateway/discovery
  body: none
  auth: apikey
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
