meta {
  name: Patch discovered operation
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/zones/:zone_id/api_gateway/discovery/operations/:operation_id
  body: json
  auth: apikey
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "state": ""
  }
}
