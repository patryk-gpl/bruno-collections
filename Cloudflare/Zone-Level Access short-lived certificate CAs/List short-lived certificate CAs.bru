meta {
  name: List short-lived certificate CAs
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/zones/:zone_id/access/apps/ca
  body: none
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
