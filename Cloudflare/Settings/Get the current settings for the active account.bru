meta {
  name: Get the current settings for the active account
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/accounts/:account_id/cni/settings
  body: none
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
