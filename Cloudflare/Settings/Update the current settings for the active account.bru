meta {
  name: Update the current settings for the active account
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/accounts/:account_id/cni/settings
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "default_asn": 0
  }
}
