meta {
  name: Create a new dataset
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accounts/:account_id/dlp/datasets
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "case_sensitive": false,
    "description": "",
    "encoding_version": 0,
    "name": "",
    "secret": false
  }
}
