meta {
  name: Delete a dataset
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/accounts/:account_id/dlp/datasets/:dataset_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  dataset_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
