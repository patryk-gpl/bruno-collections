meta {
  name: Sets the column information for a multi-column upload
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/accounts/:account_id/dlp/datasets/:dataset_id/versions/:version
  body: json
  auth: apikey
}

params:path {
  account_id: 
  dataset_id: 
  version: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  [
    {}
  ]
}
