meta {
  name: Update details about a dataset
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/accounts/:account_id/dlp/datasets/:dataset_id
  body: json
  auth: apikey
}

params:path {
  account_id: 
  dataset_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "case_sensitive": false,
    "description": "",
    "name": ""
  }
}
