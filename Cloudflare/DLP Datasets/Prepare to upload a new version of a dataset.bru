meta {
  name: Prepare to upload a new version of a dataset
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/accounts/:account_id/dlp/datasets/:dataset_id/upload
  body: none
  auth: apikey
}

params:path {
  account_id: 
  dataset_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
