meta {
  name: Get Event
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/accounts/:account_id/magic/connectors/:connector_id/telemetry/events/:event_t.:event_n
  body: none
  auth: apikey
}

params:path {
  account_id: 
  connector_id: 
  event_t: 
  event_n: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
