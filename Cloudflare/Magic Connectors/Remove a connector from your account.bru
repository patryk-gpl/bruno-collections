meta {
  name: Remove a connector from your account
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/accounts/:account_id/magic/connectors/:connector_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  connector_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
