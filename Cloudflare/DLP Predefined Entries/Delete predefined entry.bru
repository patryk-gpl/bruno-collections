meta {
  name: Delete predefined entry
  type: http
  seq: 2
}

delete {
  url: {{baseUrl}}/accounts/:account_id/dlp/entries/predefined/:entry_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  entry_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
