meta {
  name: Get latest Internet outages and anomalies
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/radar/annotations/outages
  body: none
  auth: apikey
}

params:query {
  ~limit: 
  ~offset: 
  ~dateRange: 
  ~dateStart: 
  ~dateEnd: 
  ~asn: 
  ~location: 
  ~format: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
