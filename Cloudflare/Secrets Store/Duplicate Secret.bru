meta {
  name: Duplicate Secret
  type: http
  seq: 11
}

post {
  url: {{baseUrl}}/accounts/:account_id/secrets_store/stores/:store_id/secrets/:secret_id/duplicate
  body: json
  auth: apikey
}

params:path {
  account_id: 
  store_id: 
  secret_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
