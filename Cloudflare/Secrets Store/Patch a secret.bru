meta {
  name: Patch a secret
  type: http
  seq: 10
}

patch {
  url: {{baseUrl}}/accounts/:account_id/secrets_store/stores/:store_id/secrets/:secret_id
  body: json
  auth: apikey
}

params:path {
  account_id: 
  store_id: 
  secret_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
