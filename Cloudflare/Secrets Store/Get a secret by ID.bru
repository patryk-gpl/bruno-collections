meta {
  name: Get a secret by ID
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/accounts/:account_id/secrets_store/stores/:store_id/secrets/:secret_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  store_id: 
  secret_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
