meta {
  name: Delete a store
  type: http
  seq: 4
}

delete {
  url: {{baseUrl}}/accounts/:account_id/secrets_store/stores/:store_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  store_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
