meta {
  name: Move a message
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/accounts/:account_id/email-security/investigate/:postfix_id/move
  body: json
  auth: apikey
}

params:path {
  account_id: 
  postfix_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "destination": ""
  }
}
