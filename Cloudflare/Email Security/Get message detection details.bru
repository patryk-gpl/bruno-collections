meta {
  name: Get message detection details
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/accounts/:account_id/email-security/investigate/:postfix_id/detections
  body: none
  auth: apikey
}

params:path {
  account_id: 
  postfix_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
