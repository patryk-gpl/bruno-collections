meta {
  name: Update Event Subscription
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/accounts/:account_id/event_subscriptions/subscriptions/:subscription_id
  body: json
  auth: apikey
}

params:path {
  account_id: 
  subscription_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "destination": {},
    "enabled": false,
    "events": [],
    "name": ""
  }
}
