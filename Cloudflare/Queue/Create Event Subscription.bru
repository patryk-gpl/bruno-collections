meta {
  name: Create Event Subscription
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accounts/:account_id/event_subscriptions/subscriptions
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "destination": {},
    "enabled": false,
    "events": [],
    "name": "",
    "source": {}
  }
}
