meta {
  name: Delete Event Subscription
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/accounts/:account_id/event_subscriptions/subscriptions/:subscription_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  subscription_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
