meta {
  name: Get Queue
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/accounts/:account_id/queues/:queue_id
  body: none
  auth: apikey
}

params:path {
  queue_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
