meta {
  name: Get Queue Purge Status
  type: http
  seq: 20
}

get {
  url: {{baseUrl}}/accounts/:account_id/queues/:queue_id/purge
  body: none
  auth: apikey
}

params:path {
  queue_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
