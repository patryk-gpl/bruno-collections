meta {
  name: Update Zero Trust list
  type: http
  seq: 6
}

put {
  url: {{baseUrl}}/accounts/:account_id/gateway/lists/:list_id
  body: json
  auth: apikey
}

params:path {
  list_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
