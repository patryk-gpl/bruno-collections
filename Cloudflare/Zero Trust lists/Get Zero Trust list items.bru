meta {
  name: Get Zero Trust list items
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/accounts/:account_id/gateway/lists/:list_id/items
  body: none
  auth: apikey
}

params:path {
  list_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
