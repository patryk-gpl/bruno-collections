meta {
  name: List mTLS certificate associations
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/accounts/:account_id/mtls_certificates/:mtls_certificate_id/associations
  body: none
  auth: apikey
}

params:path {
  mtls_certificate_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
