meta {
  name: Delete mTLS certificate
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/accounts/:account_id/mtls_certificates/:mtls_certificate_id
  body: json
  auth: apikey
}

params:path {
  mtls_certificate_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
