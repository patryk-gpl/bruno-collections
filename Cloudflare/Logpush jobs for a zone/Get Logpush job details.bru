meta {
  name: Get Logpush job details
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/zones/:zone_id/logpush/jobs/:job_id
  body: none
  auth: apikey
}

params:path {
  job_id: 
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
