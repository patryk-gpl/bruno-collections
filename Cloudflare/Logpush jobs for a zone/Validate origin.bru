meta {
  name: Validate origin
  type: http
  seq: 12
}

post {
  url: {{baseUrl}}/zones/:zone_id/logpush/validate/origin
  body: json
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "logpull_options": ""
  }
}
