meta {
  name: Retrieve embed Code HTML
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/accounts/:account_id/stream/:identifier/embed
  body: none
  auth: apikey
}

params:path {
  identifier: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
