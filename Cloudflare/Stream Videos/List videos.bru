meta {
  name: List videos
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/accounts/:account_id/stream
  body: none
  auth: apikey
}

params:query {
  ~status: 
  ~creator: 
  ~type: 
  ~asc: 
  ~video_name: 
  ~search: 
  ~start: 
  ~end: 
  ~include_counts: 
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
