meta {
  name: List WAF rules
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/zones/:zone_id/firewall/waf/packages/:package_id/rules
  body: none
  auth: apikey
}

params:query {
  ~mode: 
  ~group_id: 
  ~page: 
  ~per_page: 
  ~order: 
  ~direction: 
  ~match: 
  ~description: 
  ~priority: 
}

params:path {
  package_id: 
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
