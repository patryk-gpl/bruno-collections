meta {
  name: Delete Prefix Delegation
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/accounts/:account_id/addressing/prefixes/:prefix_id/delegations/:delegation_id
  body: json
  auth: apikey
}

params:path {
  delegation_id: 
  prefix_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
