meta {
  name: Create Prefix Delegation
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accounts/:account_id/addressing/prefixes/:prefix_id/delegations
  body: json
  auth: apikey
}

params:path {
  prefix_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
