meta {
  name: Delete an SSH Certificate Authority (CA)
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/accounts/:account_id/access/gateway_ca/:certificate_id
  body: none
  auth: apikey
}

params:path {
  certificate_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
