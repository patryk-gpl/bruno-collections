meta {
  name: Get Internet Quality Index (IQI) summary
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/radar/quality/iqi/summary
  body: none
  auth: apikey
}

params:query {
  metric: 
  ~name: 
  ~dateRange: 
  ~dateStart: 
  ~dateEnd: 
  ~asn: 
  ~location: 
  ~continent: 
  ~format: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
