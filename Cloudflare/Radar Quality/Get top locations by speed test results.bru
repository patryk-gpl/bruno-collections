meta {
  name: Get top locations by speed test results
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/radar/quality/speed/top/locations
  body: none
  auth: apikey
}

params:query {
  ~limit: 
  ~name: 
  ~dateEnd: 
  ~asn: 
  ~location: 
  ~continent: 
  ~orderBy: 
  ~reverse: 
  ~format: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
