meta {
  name: Get job progress
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/accounts/:account_id/slurper/jobs/:job_id/progress
  body: none
  auth: apikey
}

params:path {
  account_id: 
  job_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
