meta {
  name: Get job details
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/accounts/:account_id/slurper/jobs/:job_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  job_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
