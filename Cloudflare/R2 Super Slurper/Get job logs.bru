meta {
  name: Get job logs
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/accounts/:account_id/slurper/jobs/:job_id/logs
  body: none
  auth: apikey
}

params:query {
  ~limit: 
  ~offset: 
}

params:path {
  account_id: 
  job_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
