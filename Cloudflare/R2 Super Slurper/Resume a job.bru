meta {
  name: Resume a job
  type: http
  seq: 8
}

put {
  url: {{baseUrl}}/accounts/:account_id/slurper/jobs/:job_id/resume
  body: none
  auth: apikey
}

params:path {
  account_id: 
  job_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
