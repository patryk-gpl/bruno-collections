meta {
  name: Patch Monitor
  type: http
  seq: 5
}

patch {
  url: {{baseUrl}}/user/load_balancers/monitors/:monitor_id
  body: json
  auth: apikey
}

params:path {
  monitor_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
