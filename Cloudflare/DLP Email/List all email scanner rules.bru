meta {
  name: List all email scanner rules
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/accounts/:account_id/dlp/email/rules
  body: none
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
