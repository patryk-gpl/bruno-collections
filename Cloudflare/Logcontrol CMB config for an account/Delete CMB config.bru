meta {
  name: Delete CMB config
  type: http
  seq: 1
}

delete {
  url: {{baseUrl}}/accounts/:account_id/logs/control/cmb/config
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
