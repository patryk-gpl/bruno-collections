meta {
  name: List all outputs associated with a specified live input
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/accounts/:account_id/stream/live_inputs/:live_input_identifier/outputs
  body: none
  auth: apikey
}

params:path {
  live_input_identifier: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
