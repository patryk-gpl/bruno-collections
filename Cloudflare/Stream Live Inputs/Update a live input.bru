meta {
  name: Update a live input
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/accounts/:account_id/stream/live_inputs/:live_input_identifier
  body: json
  auth: apikey
}

params:path {
  live_input_identifier: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
