meta {
  name: Delete an output
  type: http
  seq: 8
}

delete {
  url: {{baseUrl}}/accounts/:account_id/stream/live_inputs/:live_input_identifier/outputs/:output_identifier
  body: json
  auth: apikey
}

params:path {
  output_identifier: 
  live_input_identifier: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
