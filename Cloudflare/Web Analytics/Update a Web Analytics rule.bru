meta {
  name: Update a Web Analytics rule
  type: http
  seq: 8
}

put {
  url: {{baseUrl}}/accounts/:account_id/rum/v2/:ruleset_id/rule/:rule_id
  body: json
  auth: apikey
}

params:path {
  account_id: 
  ruleset_id: 
  rule_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "host": "",
    "inclusive": false,
    "is_paused": false,
    "paths": []
  }
}
