meta {
  name: Update a Web Analytics site
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/accounts/:account_id/rum/site_info/:site_id
  body: json
  auth: apikey
}

params:path {
  account_id: 
  site_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "auto_install": false,
    "enabled": false,
    "host": "",
    "lite": false,
    "zone_tag": ""
  }
}
