meta {
  name: Get a Web Analytics site
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/accounts/:account_id/rum/site_info/:site_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  site_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
