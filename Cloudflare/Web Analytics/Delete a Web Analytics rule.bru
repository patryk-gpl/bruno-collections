meta {
  name: Delete a Web Analytics rule
  type: http
  seq: 7
}

delete {
  url: {{baseUrl}}/accounts/:account_id/rum/v2/:ruleset_id/rule/:rule_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  ruleset_id: 
  rule_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
