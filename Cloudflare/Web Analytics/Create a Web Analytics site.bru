meta {
  name: Create a Web Analytics site
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/accounts/:account_id/rum/site_info
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "auto_install": false,
    "host": "",
    "zone_tag": ""
  }
}
