  auth: apikey
}

params:path {
  account_id: 
  ruleset_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "host": "",
    "inclusive": false,
    "is_paused": false,
    "paths": []
  }
}
