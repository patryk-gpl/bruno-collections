meta {
  name: Get users
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/accounts/:account_id/access/users
  body: none
  auth: apikey
}

params:query {
  ~name: 
  ~email: 
  ~search: 
  ~page: 
  ~per_page: 
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
