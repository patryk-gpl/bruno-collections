meta {
  name: Get single active session
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/accounts/:account_id/access/users/:user_id/active_sessions/:nonce
  body: none
  auth: apikey
}

params:path {
  user_id: 
  account_id: 
  nonce: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
