meta {
  name: Get last seen identity
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/accounts/:account_id/access/users/:user_id/last_seen_identity
  body: none
  auth: apikey
}

params:path {
  user_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
