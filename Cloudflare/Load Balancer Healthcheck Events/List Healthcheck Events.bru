meta {
  name: List Healthcheck Events
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/user/load_balancing_analytics/events
  body: none
  auth: apikey
}

params:query {
  ~until: 
  ~pool_name: 
  ~origin_healthy: 
  ~pool_id: 
  ~since: 
  ~origin_name: 
  ~pool_healthy: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
