meta {
  name: Update multiple interconnects
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/accounts/:account_id/magic/cf_interconnects
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
  ~x-magic-new-hc-target: 
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
