meta {
  name: Update an entry in impersonation registry
  type: http
  seq: 22
}

patch {
  url: {{baseUrl}}/accounts/:account_id/email-security/settings/impersonation_registry/:display_name_id
  body: json
  auth: apikey
}

params:path {
  account_id: 
  display_name_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "email": "",
    "is_email_regex": false,
    "name": ""
  }
}
