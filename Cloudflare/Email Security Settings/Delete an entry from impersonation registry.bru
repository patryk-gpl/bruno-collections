meta {
  name: Delete an entry from impersonation registry
  type: http
  seq: 20
}

delete {
  url: {{baseUrl}}/accounts/:account_id/email-security/settings/impersonation_registry/:display_name_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  display_name_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
