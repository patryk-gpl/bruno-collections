meta {
  name: Unprotect an email domain
  type: http
  seq: 15
}

delete {
  url: {{baseUrl}}/accounts/:account_id/email-security/settings/domains/:domain_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  domain_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
