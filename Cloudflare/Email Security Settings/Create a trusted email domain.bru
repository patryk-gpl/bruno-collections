meta {
  name: Create a trusted email domain
  type: http
  seq: 25
}

post {
  url: {{baseUrl}}/accounts/:account_id/email-security/settings/trusted_domains
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
