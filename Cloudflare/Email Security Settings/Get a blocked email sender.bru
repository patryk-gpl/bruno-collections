meta {
  name: Get a blocked email sender
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/accounts/:account_id/email-security/settings/block_senders/:pattern_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  pattern_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
