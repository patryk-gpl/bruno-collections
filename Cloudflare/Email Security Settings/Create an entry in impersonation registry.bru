meta {
  name: Create an entry in impersonation registry
  type: http
  seq: 19
}

post {
  url: {{baseUrl}}/accounts/:account_id/email-security/settings/impersonation_registry
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "email": "",
    "is_email_regex": false,
    "name": ""
  }
}
