meta {
  name: Update entry
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/accounts/:account_id/dlp/entries/:entry_id
  body: json
  auth: apikey
}

params:path {
  account_id: 
  entry_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
