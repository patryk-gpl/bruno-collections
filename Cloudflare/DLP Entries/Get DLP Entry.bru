meta {
  name: Get DLP Entry
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/accounts/:account_id/dlp/entries/:entry_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  entry_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
