meta {
  name: Delete an ASN
  type: http
  seq: 4
}

delete {
  url: {{baseUrl}}/accounts/:account_id/botnet_feed/configs/asn/:asn_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  asn_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
