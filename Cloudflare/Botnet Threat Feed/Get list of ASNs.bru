meta {
  name: Get list of ASNs
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/accounts/:account_id/botnet_feed/configs/asn
  body: none
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
