meta {
  name: Get full report
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/accounts/:account_id/botnet_feed/asn/:asn_id/full_report
  body: none
  auth: apikey
}

params:path {
  account_id: 
  asn_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
