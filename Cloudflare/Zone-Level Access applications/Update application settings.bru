meta {
  name: Update application settings
  type: http
  seq: 8
}

put {
  url: {{baseUrl}}/zones/:zone_id/access/apps/:app_id/settings
  body: json
  auth: apikey
}

params:path {
  app_id: 
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "allow_iframe": false,
    "skip_interstitial": false
  }
}
