meta {
  name: Revoke application tokens
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/zones/:zone_id/access/apps/:app_id/revoke_tokens
  body: none
  auth: apikey
}

params:path {
  app_id: 
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
