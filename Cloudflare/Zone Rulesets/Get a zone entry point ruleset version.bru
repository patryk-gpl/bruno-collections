meta {
  name: Get a zone entry point ruleset version
  type: http
  seq: 16
}

get {
  url: {{baseUrl}}/zones/:zone_id/rulesets/phases/:ruleset_phase/entrypoint/versions/:ruleset_version
  body: none
  auth: bearer
}

params:path {
  ruleset_version: 
  ruleset_phase: 
  zone_id: 
}

auth:bearer {
  token: {{token}}
}
