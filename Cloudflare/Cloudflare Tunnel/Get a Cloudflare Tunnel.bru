meta {
  name: Get a Cloudflare Tunnel
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/accounts/:account_id/cfd_tunnel/:tunnel_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  tunnel_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
