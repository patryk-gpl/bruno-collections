meta {
  name: Update a Cloudflare Tunnel
  type: http
  seq: 5
}

patch {
  url: {{baseUrl}}/accounts/:account_id/cfd_tunnel/:tunnel_id
  body: json
  auth: apikey
}

params:path {
  tunnel_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "name": "",
    "tunnel_secret": ""
  }
}
