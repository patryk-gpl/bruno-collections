meta {
  name: Create a Cloudflare Tunnel
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accounts/:account_id/cfd_tunnel
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "config_src": "",
    "name": "",
    "tunnel_secret": ""
  }
}
