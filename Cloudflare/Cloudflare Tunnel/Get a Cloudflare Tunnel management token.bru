meta {
  name: Get a Cloudflare Tunnel management token
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/accounts/:account_id/cfd_tunnel/:tunnel_id/management
  body: json
  auth: apikey
}

params:path {
  account_id: 
  tunnel_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "resources": []
  }
}
