meta {
  name: Get a Warp Connector Tunnel
  type: http
  seq: 15
}

get {
  url: {{baseUrl}}/accounts/:account_id/warp_connector/:tunnel_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  tunnel_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
