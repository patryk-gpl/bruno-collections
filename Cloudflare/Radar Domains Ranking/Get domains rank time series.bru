meta {
  name: Get domains rank time series
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/radar/ranking/timeseries_groups
  body: none
  auth: apikey
}

params:query {
  ~limit: 
  ~rankingType: 
  ~name: 
  ~location: 
  ~domains: 
  ~domainCategory: 
  ~dateRange: 
  ~dateStart: 
  ~dateEnd: 
  ~format: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
