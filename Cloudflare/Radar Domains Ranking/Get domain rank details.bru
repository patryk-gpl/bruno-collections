meta {
  name: Get domain rank details
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/radar/ranking/domain/:domain
  body: none
  auth: apikey
}

params:query {
  ~limit: 
  ~rankingType: 
  ~name: 
  ~includeTopLocations: 
  ~date: 
  ~format: 
}

params:path {
  domain: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
