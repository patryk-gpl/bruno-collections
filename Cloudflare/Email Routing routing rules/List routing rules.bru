meta {
  name: List routing rules
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/zones/:zone_id/email/routing/rules
  body: none
  auth: apikey
}

params:query {
  ~page: 
  ~per_page: 
  ~enabled: 
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
