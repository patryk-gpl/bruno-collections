meta {
  name: Create routing rule
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/zones/:zone_id/email/routing/rules
  body: json
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "actions": [
      {
        "type": "",
        "value": []
      }
    ],
    "enabled": false,
    "matchers": [
      {
        "field": "",
        "type": "",
        "value": ""
      }
    ],
    "name": "",
    "priority": ""
  }
}
