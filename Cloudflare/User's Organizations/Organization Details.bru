meta {
  name: Organization Details
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/user/organizations/:organization_id
  body: none
  auth: apikey
}

params:path {
  organization_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
