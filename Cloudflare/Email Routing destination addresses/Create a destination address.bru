meta {
  name: Create a destination address
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accounts/:account_id/email/routing/addresses
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "email": ""
  }
}
