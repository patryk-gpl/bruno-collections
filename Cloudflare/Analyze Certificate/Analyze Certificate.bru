meta {
  name: Analyze Certificate
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/zones/:zone_id/ssl/analyze
  body: json
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "bundle_method": "",
    "certificate": ""
  }
}
