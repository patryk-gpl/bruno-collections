    "hub_provider_id": "",
    "install_routes_in_cloud": false,
    "install_routes_in_magic_wan": false,
    "manage_hub_to_hub_attachments": false,
    "manage_vpc_to_hub_attachments": false,
    "name": "",
    "region": "",
    "type": "",
    "vpc": ""
  }
}
