meta {
  name: Create On-ramp
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accounts/:account_id/magic/cloud/onramps
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
  ~forwarded: 
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "adopted_hub_id": "",
    "attached_hubs": [],
    "attached_vpcs": [],
    "cloud_type": "",
