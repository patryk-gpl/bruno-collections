meta {
  name: List all risk score integrations for the account.
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/accounts/:account_id/zt_risk_scoring/integrations
  body: none
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
