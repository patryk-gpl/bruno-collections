meta {
  name: Delete a risk score integration.
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/accounts/:account_id/zt_risk_scoring/integrations/:integration_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  integration_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
