meta {
  name: Get announced IP address space time series
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/radar/bgp/ips/timeseries
  body: none
  auth: apikey
}

params:query {
  ~name: 
  ~dateRange: 
  ~dateStart: 
  ~dateEnd: 
  ~asn: 
  ~location: 
  ~ipVersion: 
  ~includeDelay: 
  ~format: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
