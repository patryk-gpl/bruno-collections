meta {
  name: Get BGP route leak events
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/radar/bgp/leaks/events
  body: none
  auth: apikey
}

params:query {
  ~page: 
  ~per_page: 
  ~eventId: 
  ~leakAsn: 
  ~involvedAsn: 
  ~involvedCountry: 
  ~dateRange: 
  ~dateStart: 
  ~dateEnd: 
  ~sortBy: 
  ~sortOrder: 
  ~format: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
