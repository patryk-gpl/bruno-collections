meta {
  name: Get Keyless SSL Configuration
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/zones/:zone_id/keyless_certificates/:keyless_certificate_id
  body: none
  auth: apikey
}

params:path {
  keyless_certificate_id: 
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
