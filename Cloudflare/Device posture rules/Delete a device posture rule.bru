meta {
  name: Delete a device posture rule
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/accounts/:account_id/devices/posture/:rule_id
  body: json
  auth: apikey
}

params:path {
  rule_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
