meta {
  name: Search for locations, ASes, reports, and more
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/radar/search/global
  body: none
  auth: apikey
}

params:query {
  query: 
  ~limit: 
  ~limitPerGroup: 
  ~include: 
  ~exclude: 
  ~format: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
