meta {
  name: Get the current status of a given Access policy test
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/accounts/:account_id/access/policy-tests/:policy_test_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  policy_test_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
