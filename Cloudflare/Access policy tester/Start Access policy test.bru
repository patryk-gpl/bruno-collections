meta {
  name: Start Access policy test
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/accounts/:account_id/access/policy-tests
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "policies": []
  }
}
