meta {
  name: Get an Access policy test users page
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/accounts/:account_id/access/policy-tests/:policy_test_id/users
  body: none
  auth: apikey
}

params:query {
  ~page: 
  ~per_page: 
  ~status: 
}

params:path {
  account_id: 
  policy_test_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
