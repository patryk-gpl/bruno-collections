meta {
  name: Delete a share recipient
  type: http
  seq: 8
}

delete {
  url: {{baseUrl}}/accounts/:account_id/shares/:share_id/recipients/:recipient_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  share_id: 
  recipient_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
