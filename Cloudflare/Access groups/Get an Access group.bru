meta {
  name: Get an Access group
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/accounts/:account_id/access/groups/:group_id
  body: none
  auth: apikey
}

params:path {
  group_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
