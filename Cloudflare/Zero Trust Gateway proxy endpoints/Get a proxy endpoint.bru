meta {
  name: Get a proxy endpoint
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/accounts/:account_id/gateway/proxy_endpoints/:proxy_endpoint_id
  body: none
  auth: apikey
}

params:path {
  proxy_endpoint_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
