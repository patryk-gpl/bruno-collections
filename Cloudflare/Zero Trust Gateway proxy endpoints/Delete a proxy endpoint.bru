meta {
  name: Delete a proxy endpoint
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/accounts/:account_id/gateway/proxy_endpoints/:proxy_endpoint_id
  body: json
  auth: apikey
}

params:path {
  proxy_endpoint_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
