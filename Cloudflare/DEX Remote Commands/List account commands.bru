meta {
  name: List account commands
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/accounts/:account_id/dex/commands
  body: none
  auth: apikey
}

params:query {
  page: 
  per_page: 
  ~from: 
  ~to: 
  ~device_id: 
  ~user_email: 
  ~command_type: 
  ~status: 
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
