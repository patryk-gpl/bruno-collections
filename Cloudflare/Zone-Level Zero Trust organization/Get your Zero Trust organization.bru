meta {
  name: Get your Zero Trust organization
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/zones/:zone_id/access/organizations
  body: none
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
