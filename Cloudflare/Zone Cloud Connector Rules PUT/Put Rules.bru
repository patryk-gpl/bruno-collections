meta {
  name: Put Rules
  type: http
  seq: 1
}

put {
  url: {{baseUrl}}/zones/:zone_id/cloud_connector/rules
  body: json
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  [
    {
      "description": "",
      "enabled": false,
      "expression": "",
      "id": "",
      "parameters": {
        "host": ""
      },
      "provider": ""
    }
  ]
}
