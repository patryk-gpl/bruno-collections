meta {
  name: Set configuration properties
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/zones/:zone_id/api_gateway/configuration
  body: json
  auth: apikey
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "auth_id_characteristics": []
  }
}
