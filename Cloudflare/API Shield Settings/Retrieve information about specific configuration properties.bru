meta {
  name: Retrieve information about specific configuration properties
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/zones/:zone_id/api_gateway/configuration
  body: none
  auth: apikey
}

params:query {
  ~properties: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
