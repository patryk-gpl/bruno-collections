meta {
  name: Get an Access application
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/accounts/:account_id/access/apps/:app_id
  body: none
  auth: apikey
}

params:path {
  app_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
