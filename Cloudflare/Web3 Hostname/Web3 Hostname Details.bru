meta {
  name: Web3 Hostname Details
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/zones/:zone_id/web3/hostnames/:identifier
  body: none
  auth: apikey
}

params:path {
  identifier: 
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
