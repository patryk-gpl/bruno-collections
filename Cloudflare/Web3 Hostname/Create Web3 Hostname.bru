meta {
  name: Create Web3 Hostname
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/zones/:zone_id/web3/hostnames
  body: json
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "description": "",
    "dnslink": "",
    "name": "",
    "target": ""
  }
}
