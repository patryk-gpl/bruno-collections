meta {
  name: Get the live status of a latest device
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/accounts/:account_id/dex/devices/:device_id/fleet-status/live
  body: none
  auth: apikey
}

params:query {
  since_minutes: 
  ~time_now: 
  ~colo: 
}

params:path {
  account_id: 
  device_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
