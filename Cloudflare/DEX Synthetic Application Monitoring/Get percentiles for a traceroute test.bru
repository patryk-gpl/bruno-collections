meta {
  name: Get percentiles for a traceroute test
  type: http
  seq: 13
}

get {
  url: {{baseUrl}}/accounts/:account_id/dex/traceroute-tests/:test_id/percentiles
  body: none
  auth: apikey
}

params:query {
  from: 
  to: 
  ~deviceId: 
  ~colo: 
}

params:path {
  account_id: 
  test_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
