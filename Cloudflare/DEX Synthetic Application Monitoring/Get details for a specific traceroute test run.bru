meta {
  name: Get details for a specific traceroute test run
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/accounts/:account_id/dex/traceroute-test-results/:test_result_id/network-path
  body: none
  auth: apikey
}

params:path {
  account_id: 
  test_result_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
