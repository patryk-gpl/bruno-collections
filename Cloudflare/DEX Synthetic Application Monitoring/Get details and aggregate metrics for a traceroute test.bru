meta {
  name: Get details and aggregate metrics for a traceroute test
  type: http
  seq: 11
}

get {
  url: {{baseUrl}}/accounts/:account_id/dex/traceroute-tests/:test_id
  body: none
  auth: apikey
}

params:query {
  from: 
  to: 
  interval: 
  ~deviceId: 
  ~colo: 
}

params:path {
  account_id: 
  test_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
