meta {
  name: Get percentiles for an http test
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/accounts/:account_id/dex/http-tests/:test_id/percentiles
  body: none
  auth: apikey
}

params:query {
  from: 
  to: 
  ~deviceId: 
  ~colo: 
}

params:path {
  account_id: 
  test_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
