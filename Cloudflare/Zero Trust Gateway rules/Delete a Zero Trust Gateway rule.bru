meta {
  name: Delete a Zero Trust Gateway rule
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/accounts/:account_id/gateway/rules/:rule_id
  body: json
  auth: apikey
}

params:path {
  rule_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
