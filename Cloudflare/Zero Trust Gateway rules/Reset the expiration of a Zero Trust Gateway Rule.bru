meta {
  name: Reset the expiration of a Zero Trust Gateway Rule
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/accounts/:account_id/gateway/rules/:rule_id/reset_expiration
  body: none
  auth: apikey
}

params:path {
  rule_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
