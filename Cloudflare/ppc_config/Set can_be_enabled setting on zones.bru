meta {
  name: Set can_be_enabled setting on zones
  type: http
  seq: 1
}

patch {
  url: {{baseUrl}}/accounts/:account_id/pay-per-crawl/zones_can_be_enabled
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "zones": [
      {
        "can_be_enabled": false,
        "id": ""
      }
    ]
  }
}
