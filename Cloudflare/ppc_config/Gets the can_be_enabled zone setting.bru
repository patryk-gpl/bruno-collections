meta {
  name: Gets the can_be_enabled zone setting
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/accounts/:account_id/pay-per-crawl/zones_can_be_enabled/query
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "zones": [
      {
        "can_be_enabled": false,
        "id": ""
      }
    ]
  }
}
