meta {
  name: Get the pay-per-crawl config
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/zones/:zone_id/pay-per-crawl/configuration
  body: none
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
