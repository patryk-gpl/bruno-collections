meta {
  name: Create a rate limit
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/zones/:zone_id/rate_limits
  body: json
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "action": {},
    "match": {},
    "period": "",
    "threshold": ""
  }
}
