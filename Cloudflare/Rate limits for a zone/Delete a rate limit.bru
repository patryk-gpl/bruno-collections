meta {
  name: Delete a rate limit
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/zones/:zone_id/rate_limits/:rate_limit_id
  body: json
  auth: apikey
}

params:path {
  rate_limit_id: 
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
