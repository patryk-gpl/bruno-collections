meta {
  name: List rate limits
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/zones/:zone_id/rate_limits
  body: none
  auth: apikey
}

params:query {
  ~page: 
  ~per_page: 
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
