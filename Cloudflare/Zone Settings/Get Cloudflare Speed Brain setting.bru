meta {
  name: Get Cloudflare Speed Brain setting
  type: http
  seq: 13
}

get {
  url: {{baseUrl}}/zones/:zone_id/settings/speed_brain
  body: none
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
