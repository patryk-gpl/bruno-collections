meta {
  name: Change Cloudflare Speed Brain setting
  type: http
  seq: 14
}

patch {
  url: {{baseUrl}}/zones/:zone_id/settings/speed_brain
  body: json
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
