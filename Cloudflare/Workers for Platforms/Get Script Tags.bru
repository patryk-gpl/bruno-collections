meta {
  name: Get Script Tags
  type: http
  seq: 22
}

get {
  url: {{baseUrl}}/accounts/:account_id/workers/dispatch/namespaces/:dispatch_namespace/scripts/:script_name/tags
  body: none
  auth: bearer
}

params:path {
  account_id: 
  dispatch_namespace: 
  script_name: 
}

auth:bearer {
  token: {{token}}
}
