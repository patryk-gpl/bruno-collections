meta {
  name: Get secret binding
  type: http
  seq: 19
}

get {
  url: {{baseUrl}}/accounts/:account_id/workers/dispatch/namespaces/:dispatch_namespace/scripts/:script_name/secrets/:secret_name
  body: none
  auth: bearer
}

params:path {
  account_id: 
  dispatch_namespace: 
  script_name: 
  secret_name: 
}

auth:bearer {
  token: {{token}}
}
