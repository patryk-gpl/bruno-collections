meta {
  name: List WAF rule groups
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/zones/:zone_id/firewall/waf/packages/:package_id/groups
  body: none
  auth: apikey
}

params:query {
  ~mode: 
  ~page: 
  ~per_page: 
  ~order: 
  ~direction: 
  ~match: 
  ~name: 
  ~rules_count: 
}

params:path {
  package_id: 
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
