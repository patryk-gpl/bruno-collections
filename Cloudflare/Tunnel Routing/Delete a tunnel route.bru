meta {
  name: Delete a tunnel route
  type: http
  seq: 3
}

delete {
  url: {{baseUrl}}/accounts/:account_id/teamnet/routes/:route_id
  body: none
  auth: apikey
}

params:path {
  route_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
