meta {
  name: Create a tunnel route (CIDR Endpoint)
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/accounts/:account_id/teamnet/routes/network/:ip_network_encoded
  body: json
  auth: apikey
}

params:path {
  ip_network_encoded: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "comment": "",
    "tunnel_id": "",
    "virtual_network_id": ""
  }
}
