meta {
  name: Update a tunnel route (CIDR Endpoint)
  type: http
  seq: 8
}

patch {
  url: {{baseUrl}}/accounts/:account_id/teamnet/routes/network/:ip_network_encoded
  body: none
  auth: apikey
}

params:path {
  ip_network_encoded: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
