meta {
  name: Get tunnel route by IP
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/accounts/:account_id/teamnet/routes/ip/:ip
  body: none
  auth: apikey
}

params:query {
  ~virtual_network_id: 
  ~default_virtual_network_fallback: 
}

params:path {
  ip: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
