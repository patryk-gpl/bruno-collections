meta {
  name: Update a tunnel route
  type: http
  seq: 5
}

patch {
  url: {{baseUrl}}/accounts/:account_id/teamnet/routes/:route_id
  body: json
  auth: apikey
}

params:path {
  route_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "comment": "",
    "network": "",
    "tunnel_id": "",
    "virtual_network_id": ""
  }
}
