meta {
  name: Get tunnel route
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/accounts/:account_id/teamnet/routes/:route_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  route_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
