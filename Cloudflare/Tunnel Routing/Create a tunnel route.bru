  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "comment": "",
    "network": "",
    "tunnel_id": "",
    "virtual_network_id": ""
  }
}
