meta {
  name: List tunnel routes
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/accounts/:account_id/teamnet/routes
  body: none
  auth: apikey
}

params:query {
  ~comment: 
  ~is_deleted: 
  ~network_subset: 
  ~network_superset: 
  ~existed_at: 
  ~tunnel_id: 
  ~route_id: 
  ~tun_types: 
  ~virtual_network_id: 
  ~per_page: 
  ~page: 
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
