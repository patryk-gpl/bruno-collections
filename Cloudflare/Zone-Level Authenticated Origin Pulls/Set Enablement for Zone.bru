meta {
  name: Set Enablement for Zone
  type: http
  seq: 6
}

put {
  url: {{baseUrl}}/zones/:zone_id/origin_tls_client_auth/settings
  body: json
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "enabled": false
  }
}
