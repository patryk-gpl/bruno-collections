meta {
  name: Get Enablement Setting for Zone
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/zones/:zone_id/origin_tls_client_auth/settings
  body: none
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
