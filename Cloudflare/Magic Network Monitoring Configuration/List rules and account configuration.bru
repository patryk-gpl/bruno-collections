meta {
  name: List rules and account configuration
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/accounts/:account_id/mnm/config/full
  body: none
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
