meta {
  name: Get Device DEX test
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/accounts/:account_id/dex/devices/dex_tests/:dex_test_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  dex_test_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
