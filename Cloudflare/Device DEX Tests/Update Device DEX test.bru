meta {
  name: Update Device DEX test
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/accounts/:account_id/dex/devices/dex_tests/:dex_test_id
  body: json
  auth: apikey
}

params:path {
  account_id: 
  dex_test_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "data": {
      "host": "",
      "kind": "",
      "method": ""
    },
    "description": "",
    "enabled": false,
    "interval": "",
    "name": "",
    "target_policies": [
      {
        "default": false,
        "id": "",
        "name": ""
      }
    ],
    "targeted": false,
    "test_id": ""
  }
}
