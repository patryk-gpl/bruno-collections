meta {
  name: Get HTML content and screenshot.
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/accounts/:account_id/browser-rendering/snapshot
  body: json
  auth: apikey
}

params:query {
  ~cacheTTL: 
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
