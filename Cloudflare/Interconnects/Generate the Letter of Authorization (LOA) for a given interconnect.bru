meta {
  name: Generate the Letter of Authorization (LOA) for a given interconnect
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/accounts/:account_id/cni/interconnects/:icon/loa
  body: none
  auth: apikey
}

params:path {
  icon: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
