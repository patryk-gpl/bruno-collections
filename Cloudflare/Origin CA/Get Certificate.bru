meta {
  name: Get Certificate
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/certificates/:certificate_id
  body: none
  auth: apikey
}

params:path {
  certificate_id: 
}

headers {
  X-Auth-User-Service-Key: {{apiKey}}
}

auth:apikey {
  key: X-Auth-User-Service-Key
  value: {{apiKey}}
  placement: header
}
