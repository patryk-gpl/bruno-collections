meta {
  name: Get email DKIM validation time series
  type: http
  seq: 11
}

get {
  url: {{baseUrl}}/radar/email/security/timeseries_groups/dkim
  body: none
  auth: apikey
}

params:query {
  ~aggInterval: 
  ~name: 
  ~dateRange: 
  ~dateStart: 
  ~dateEnd: 
  ~arc: 
  ~dmarc: 
  ~spf: 
  ~tlsVersion: 
  ~format: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
