meta {
  name: Get top locations by HTTP requests for an HTTP version
  type: http
  seq: 36
}

get {
  url: {{baseUrl}}/radar/http/top/locations/http_version/:http_version
  body: none
  auth: apikey
}

params:query {
  ~limit: 
  ~name: 
  ~dateRange: 
  ~dateStart: 
  ~dateEnd: 
  ~asn: 
  ~location: 
  ~continent: 
  ~botClass: 
  ~deviceType: 
  ~httpProtocol: 
  ~ipVersion: 
  ~os: 
  ~tlsVersion: 
  ~browserFamily: 
  ~format: 
}

params:path {
  http_version: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
