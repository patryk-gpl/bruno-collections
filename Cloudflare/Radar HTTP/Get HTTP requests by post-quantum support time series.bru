meta {
  name: Get HTTP requests by post-quantum support time series
  type: http
  seq: 18
}

get {
  url: {{baseUrl}}/radar/http/timeseries_groups/post_quantum
  body: none
  auth: apikey
}

params:query {
  ~aggInterval: 
  ~name: 
  ~dateRange: 
  ~dateStart: 
  ~dateEnd: 
  ~asn: 
  ~location: 
  ~continent: 
  ~botClass: 
  ~deviceType: 
  ~httpProtocol: 
  ~httpVersion: 
  ~ipVersion: 
  ~os: 
  ~tlsVersion: 
  ~browserFamily: 
  ~format: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
