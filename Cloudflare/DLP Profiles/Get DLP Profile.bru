meta {
  name: Get DLP Profile
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/accounts/:account_id/dlp/profiles/:profile_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  profile_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
