meta {
  name: Create predefined profile
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/accounts/:account_id/dlp/profiles/predefined
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
