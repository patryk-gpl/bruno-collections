meta {
  name: Get predefined profile
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/accounts/:account_id/dlp/profiles/predefined/:profile_id
  body: none
  auth: apikey
}

params:path {
  account_id: 
  profile_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
