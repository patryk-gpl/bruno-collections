meta {
  name: Get rule
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/accounts/:account_id/mnm/rules/:rule_id
  body: none
  auth: apikey
}

params:path {
  rule_id: 
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
