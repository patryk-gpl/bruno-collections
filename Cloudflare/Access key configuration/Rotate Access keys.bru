meta {
  name: Rotate Access keys
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/accounts/:account_id/access/keys/rotate
  body: none
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
