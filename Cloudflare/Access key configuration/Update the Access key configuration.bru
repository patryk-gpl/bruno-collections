meta {
  name: Update the Access key configuration
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/accounts/:account_id/access/keys
  body: json
  auth: apikey
}

params:path {
  account_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
