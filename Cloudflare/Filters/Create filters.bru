meta {
  name: Create filters
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/zones/:zone_id/filters
  body: json
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  [
    {
      "description": "",
      "expression": "",
      "id": "",
      "paused": false,
      "ref": ""
    }
  ]
}
