meta {
  name: Delete a filter
  type: http
  seq: 5
}

delete {
  url: {{baseUrl}}/zones/:zone_id/filters/:filter_id
  body: none
  auth: apikey
}

params:path {
  filter_id: 
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
