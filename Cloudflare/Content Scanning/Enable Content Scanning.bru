meta {
  name: Enable Content Scanning
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/zones/:zone_id/content-upload-scan/enable
  body: none
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
