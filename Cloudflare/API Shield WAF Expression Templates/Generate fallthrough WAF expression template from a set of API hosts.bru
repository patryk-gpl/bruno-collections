meta {
  name: Generate fallthrough WAF expression template from a set of API hosts
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/zones/:zone_id/api_gateway/expression-template/fallthrough
  body: json
  auth: apikey
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}

body:json {
  {
    "hosts": []
  }
}
