meta {
  name: List bots
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/radar/bots
  body: none
  auth: apikey
}

params:query {
  ~limit: 
  ~offset: 
  ~botCategory: 
  ~botOperator: 
  ~kind: 
  ~botVerificationStatus: 
  ~format: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
