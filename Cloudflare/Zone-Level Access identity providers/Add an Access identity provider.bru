meta {
  name: Add an Access identity provider
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/zones/:zone_id/access/identity_providers
  body: json
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
