meta {
  name: List all mTLS hostname settings
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/zones/:zone_id/access/certificates/settings
  body: none
  auth: apikey
}

params:path {
  zone_id: 
}

headers {
  X-Auth-Email: {{apiKey}}
}

auth:apikey {
  key: X-Auth-Email
  value: {{apiKey}}
  placement: header
}
